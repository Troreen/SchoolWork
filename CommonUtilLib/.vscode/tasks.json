{
    "version": "2.0.0",
    "windows": {
        "options": {
            "shell": {
                "executable": "cmd.exe",
                "args": [
                    "/C",
                    "\"%ProgramFiles%\\Microsoft Visual Studio\\2022\\Community\\Common7\\Tools\\VsDevCmd.bat\" && "
                ]
            }
        }
    },
    "tasks": [
        {
            "label": "Build Solution (Debug x64)",
            "type": "shell",
            "command": "msbuild",
            "args": [
                "${workspaceFolder}/CommonUtilLib.sln",
                "/p:Configuration=Debug",
                "/p:Platform=x64",
                "/m"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$msCompile",
            "detail": "Build the entire solution in Debug x64"
        },
        {
            "label": "Build Solution (Release x64)",
            "type": "shell",
            "command": "msbuild",
            "args": [
                "${workspaceFolder}/CommonUtilLib.sln",
                "/p:Configuration=Release",
                "/p:Platform=x64",
                "/m"
            ],
            "group": "build",
            "problemMatcher": "$msCompile",
            "detail": "Build the entire solution in Release x64"
        },
        {
            "label": "Run Tests",
            "type": "shell",
            "command": "vstest.console.exe",
            "args": [
                "${workspaceFolder}/x64/Debug/MathTests.dll"
            ],
            "group": "test",
            "problemMatcher": [],
            "dependsOn": "Build Solution (Debug x64)",
            "detail": "Build and run unit tests"
        },
        {
            "label": "Clean Solution",
            "type": "shell",
            "command": "msbuild",
            "args": [
                "${workspaceFolder}/CommonUtilLib.sln",
                "/t:Clean",
                "/p:Configuration=Debug",
                "/p:Platform=x64"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}
