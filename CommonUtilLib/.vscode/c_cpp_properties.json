{
    "configurations": [
        {
            "name": "Win32",
            "includePath": [
                "${workspaceFolder}/**",
                "${env:ProgramFiles}/Microsoft Visual Studio/2022/Community/VC/Tools/MSVC/*/include",
                "${env:ProgramFiles}/Microsoft Visual Studio/2022/Community/VC/Auxiliary/VS/UnitTest/include",
                "${env:ProgramFiles(x86)}/Windows Kits/10/Include/*/ucrt",
                "${env:ProgramFiles(x86)}/Windows Kits/10/Include/*/um",
                "${env:ProgramFiles(x86)}/Windows Kits/10/Include/*/shared"
            ],
            "defines": [
                "_DEBUG",
                "UNICODE",
                "_UNICODE",
                "WIN32"
            ],
            "windowsSdkVersion": "10.0",
            "compilerPath": "cl.exe",
            "cStandard": "c17",
            "cppStandard": "c++17",
            "intelliSenseMode": "windows-msvc-x64",
            "configurationProvider": "ms-vscode.cmake-tools"
        }
    ],
    "version": 4
}
